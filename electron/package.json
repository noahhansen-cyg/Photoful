{
  "name": "photoful",
  "version": "0.1.0",
  "description": "A party photo game for TV + phones",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-builder",
    "package:dir": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.photoful.app",
    "productName": "Photoful",
    "directories": {
      "output": "../dist"
    },
    "files": [
      "main.js"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/photoful-server",
        "to": "server"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "tar.gz"
      ],
      "category": "Game"
    }
  }
}
